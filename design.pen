                      "fill": "$muted-fg",
                      "textGrowth": "fixed-width",
                      "width": 672,
                      "content": "This is an MDX version of my group's CSE 595 final project on multi-label rhetorical frame classification in U.S. Congressional speeches. It combines dataset construction, few-shot LLM labeling, and classical plus transformer baselines.",
                      "lineHeight": 1.7,
                      "fontFamily": "Inter",
                      "fontSize": 16,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "yUB1k",
                      "fill": "$fg",
