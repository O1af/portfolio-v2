                    },
                    {
                      "type": "text",
                      "id": "FaVCe",
                      "fill": "$muted-fg",
                      "textGrowth": "fixed-width",
                      "width": 672,
                      "content": "Olaf Dsouza, Joshua Hsueh, and Yana Patel collaborated on the project, with the final write-up comparing TF-IDF + LinearSVC against a finetuned DistilBERT model.",
                      "lineHeight": 1.7,
                      "fontFamily": "Inter",
                      "fontSize": 16,
                      "fontWeight": "normal"
                    },
